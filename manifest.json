{
  "manifest_version": 3,
  "name": "Ekagra YouTube Focus",
  "version": "1.0.0",
  "description": "Blocks YouTube Shorts and recommendation sections.",
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
